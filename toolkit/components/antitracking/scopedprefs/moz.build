with Files("**"):
    BUG_COMPONENT = ("Core", "Privacy: Anti-Tracking")

XPIDL_SOURCES += [
    "nsIScopedPrefs.idl",
]

XPIDL_MODULE = "toolkit_antitracking"

XPCOM_MANIFESTS += [
    "components.conf",
]

UNIFIED_SOURCES += [
    "ScopedPrefs.cpp",
]

EXPORTS.mozilla += [
    "ScopedPrefs.h",
]

LOCAL_INCLUDES += [
    "!/ipc/ipdl/_ipdlheaders",
    "/ipc/chromium/src",
]

BROWSER_CHROME_MANIFESTS += [
    "test/browser/browser.toml",
]

FINAL_LIBRARY = "xul"
