with Files("**"):
    BUG_COMPONENT = ("Core", "DOM: Core & HTML")

EXPORTS += [
    "nsIScriptElement.h",
    "nsIScriptLoaderObserver.h",
]

EXPORTS.mozilla.dom += [
    "AutoEntryScript.h",
    "ModuleLoader.h",
    "ScriptCompression.h",
    "ScriptDecoding.h",
    "ScriptElement.h",
    "ScriptLoadContext.h",
    "ScriptLoader.h",
    "ScriptLoadHandler.h",
    "ScriptLoadRequestType.h",
    "ScriptSettings.h",
    "ScriptTrace.h",
    "SharedScriptCache.h",
]

UNIFIED_SOURCES += [
    "AutoEntryScript.cpp",
    "ModuleLoader.cpp",
    "nsIScriptElement.cpp",
    "ScriptCompression.cpp",
    "ScriptElement.cpp",
    "ScriptLoadContext.cpp",
    "ScriptLoader.cpp",
    "ScriptLoadHandler.cpp",
    "ScriptSettings.cpp",
    "ScriptTrace.cpp",
    "SharedScriptCache.cpp",
]

LOCAL_INCLUDES += [
    "/dom/base",
    "/js/loader",
    # For nsHttpChannel.h
    "/netwerk/base",
    "/netwerk/protocol/http",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul"
