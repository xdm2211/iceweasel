include protocol PJSValidator;

namespace mozilla {
namespace dom {

// PJSOracle is a top-level actor which manages PJSValidator
[ChildProc=Utility]
async protocol PJSOracle {
  manages PJSValidator;

child:
  async PJSValidator();
};

}  // namespace dom
}  // namespace mozilla
