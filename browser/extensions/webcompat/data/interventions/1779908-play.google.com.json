{
  "label": "play.google.com",
  "bugs": {
    "1779908": {
      "issue": "extra-scrollbars",
      "matches": ["*://play.google.com/store/*"]
    }
  },
  "interventions": [
    {
      "platforms": ["desktop"],
      "max_version": 150,
      "content_scripts": {
        "css": ["bug1779908-play.google.com-scrollbar-fix.css"]
      }
    },
    {
      "platforms": ["desktop"],
      "min_version": 151,
      "pref_check": {
        "layout.css.fake-webkit-scrollbar.enabled": false
      },
      "content_scripts": {
        "css": ["bug1779908-play.google.com-scrollbar-fix.css"]
      }
    }
  ]
}
