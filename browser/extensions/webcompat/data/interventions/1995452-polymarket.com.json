{
  "label": "polymarket.com",
  "bugs": {
    "1995452": {
      "issue": "extra-scrollbars",
      "matches": ["*://polymarket.com/*"]
    }
  },
  "interventions": [
    {
      "platforms": ["desktop"],
      "max_version": 150,
      "content_scripts": {
        "css": ["1995452-polymarket.com-hide-scrollbars.css"]
      }
    },
    {
      "platforms": ["desktop"],
      "min_version": 151,
      "pref_check": {
        "layout.css.fake-webkit-scrollbar.enabled": false
      },
      "content_scripts": {
        "css": ["1995452-polymarket.com-hide-scrollbars.css"]
      }
    }
  ]
}
