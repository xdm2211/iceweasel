Library("ipcgluetest")

EXPORTS.mozilla.gtest.ipc += [
    "TestUtilityProcess.h",
]

UNIFIED_SOURCES = [
    "TestAsyncBlockers.cpp",
    "TestUtilityProcess.cpp",
    "TestUtilityProcessSandboxing.cpp",
]

LOCAL_INCLUDES += [
    "/widget",
    "/widget/android",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul-gtest"
